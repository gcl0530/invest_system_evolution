.kline-container {
  width: 100%;
  background-color: #1a1a2e;
}

.indicator-bar {
  display: flex;
  flex-direction: row;
  padding: 12rpx 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #2a2a4a;
  overflow-x: auto;
  white-space: nowrap;
}

.indicator-toggle {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #8a8aa0;
  background-color: rgba(255, 255, 255, 0.04);
  transition: all 0.2s;
}

.indicator-toggle.active {
  color: #fff;
  background-color: #e94560;
}

.kline-canvas {
  width: 100%;
  height: 500rpx;
  display: block;
}
