/* components/backtest-chart/backtest-chart.wxss */

.backtest-chart-container {
  display: flex;
  flex-direction: column;
}

/* Tab */
.chart-tabs {
  display: flex;
  flex-direction: row;
  background-color: #1a1a2e;
  border-radius: 8rpx;
  margin: 0 0 16rpx;
  overflow: hidden;
}

.chart-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #8a8aa0;
  transition: all 0.2s;
}

.chart-tab.active {
  background-color: rgba(233, 69, 96, 0.15);
  color: #e94560;
  font-weight: 600;
}

/* 图表 */
.chart-area {
  background-color: #0f0f1e;
  border-radius: 8rpx;
  overflow: hidden;
}

.backtest-canvas {
  display: block;
}

/* 指标卡片 */
.metrics-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0;
}

.metric-item {
  flex: 1;
  min-width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background-color: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
}

.metric-label {
  font-size: 20rpx;
  color: #5a5a70;
}

.metric-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #e8e8f0;
  margin-top: 4rpx;
}

/* 交易记录 */
.trades-list {
  max-height: 800rpx;
}

.trade-item {
  background-color: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.trade-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.trade-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.trade-date {
  font-size: 22rpx;
  color: #5a5a70;
}

.trade-details {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.trade-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.trade-label {
  font-size: 22rpx;
  color: #5a5a70;
}

.trade-value {
  font-size: 24rpx;
  color: #e8e8f0;
}

.trade-reason {
  font-size: 22rpx;
  color: #8a8aa0;
}

.empty-trades {
  text-align: center;
  padding: 60rpx 0;
  color: #5a5a70;
  font-size: 24rpx;
}
