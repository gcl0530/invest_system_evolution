/* pages/philosophy/philosophy.wxss */

/* 标题栏 */
.philosophy-header {
  padding: 32rpx 32rpx 24rpx;
  text-align: center;
}

.philosophy-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8e8f0;
  display: block;
}

.philosophy-subtitle {
  font-size: 24rpx;
  color: #8a8aa0;
  margin-top: 8rpx;
  display: block;
  letter-spacing: 8rpx;
}

/* 层级选择器 */
.level-selector {
  display: flex;
  flex-direction: row;
  padding: 0 16rpx;
  gap: 8rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 24rpx;
}

.level-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  background-color: #1a1a2e;
  border: 1rpx solid #2a2a4a;
  min-width: 120rpx;
  transition: all 0.2s;
}

.level-item.active {
  border-color: #e94560;
  background-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 0 16rpx rgba(0, 0, 0, 0.3);
}

.level-char {
  font-size: 40rpx;
  font-weight: 700;
  color: #e94560;
  font-family: 'PingFang SC', serif;
}

.level-text {
  font-size: 20rpx;
  color: #8a8aa0;
  margin-top: 4rpx;
}

/* 层级内容 */
.level-content {
  padding-bottom: 120rpx;
}

.level-header {
  text-align: center;
  padding: 32rpx 24rpx;
}

.level-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #e8e8f0;
}

.level-subtitle {
  font-size: 24rpx;
  color: #8a8aa0;
  margin-top: 8rpx;
  display: block;
}

/* 条目列表 */
.item-list {
  padding: 0 0 24rpx;
}

.philosophy-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8e8f0;
  padding-left: 16rpx;
  border-left: 6rpx solid #e94560;
}

.item-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.action-btn {
  font-size: 22rpx;
  color: #8a8aa0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.06);
}

.action-btn.danger {
  color: #26a69a;
}

.item-content {
  padding: 8rpx 0;
}

.content-text {
  font-size: 26rpx;
  color: #8a8aa0;
  line-height: 1.8;
}

/* 编辑模式 */
.edit-mode {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.edit-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

/* 添加按钮 */
.add-section {
  padding: 24rpx 32rpx;
}

/* 弹层 */
.add-popup {
  padding: 32rpx;
  background-color: #1a1a2e;
  border-radius: 20rpx 20rpx 0 0;
}

.popup-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e8e8f0;
}

.popup-close {
  font-size: 24rpx;
  color: #8a8aa0;
}

.popup-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-label {
  font-size: 24rpx;
  color: #8a8aa0;
}
