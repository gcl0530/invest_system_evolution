/* pages/backtest/backtest.wxss */

.config-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  color: #8a8aa0;
  font-weight: 500;
}

.type-selector {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.04);
  color: #8a8aa0;
  font-size: 26rpx;
}

.type-option.active {
  background-color: #e94560;
  color: #fff;
}

/* 搜索结果 */
.search-results {
  background-color: #1a1a2e;
  border-radius: 8rpx;
  border: 1rpx solid #2a2a4a;
  max-height: 400rpx;
  overflow-y: auto;
}

.search-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.search-item:last-child {
  border-bottom: none;
}

.search-code {
  font-size: 24rpx;
  color: #e94560;
  font-weight: 600;
  min-width: 140rpx;
}

.search-name {
  font-size: 24rpx;
  color: #e8e8f0;
}

/* 金字塔参数 */
.pyramid-params {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx;
  background-color: rgba(255, 255, 255, 0.02);
  border-radius: 8rpx;
}

.param-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.param-label {
  font-size: 26rpx;
  color: #8a8aa0;
}

.param-control {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  background-color: rgba(255, 255, 255, 0.08);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.param-unit {
  font-size: 22rpx;
  color: #8a8aa0;
  font-weight: 500;
}

/* Stepper 数字强制可见（黑背景场景）- 高权重选择器 */
page .t-stepper__input,
.t-stepper .t-stepper__input,
.t-stepper--default .t-stepper__input,
.backtest-stepper .t-stepper__input {
  color: #ffffff !important;
  background-color: rgba(255, 255, 255, 0.15) !important;
  font-weight: 700 !important;
  font-size: 28rpx !important;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3) !important;
}

page .t-stepper__minus,
page .t-stepper__plus,
.t-stepper .t-stepper__minus,
.t-stepper .t-stepper__plus,
.backtest-stepper .t-stepper__minus,
.backtest-stepper .t-stepper__plus {
  color: #ffffff !important;
  background-color: rgba(255, 255, 255, 0.12) !important;
  border-color: rgba(255, 255, 255, 0.2) !important;
}

/* 直接覆盖 input 元素样式 */
page .t-stepper input,
.backtest-stepper input {
  color: #ffffff !important;
  background-color: rgba(255, 255, 255, 0.18) !important;
}

/* 自定义 stepper 容器样式增强 */
.backtest-stepper {
  --td-stepper-input-color: #ffffff !important;
  --td-stepper-input-bg: rgba(255,255,255,0.15) !important;
}

/* 条件预览 */
.conditions-preview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.condition-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.condition-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background-color: rgba(124, 77, 255, 0.15);
  color: #7c4dff;
  font-size: 20rpx;
}

/* 结果摘要 */
.result-summary {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-item {
  flex: 1;
  min-width: 40%;
  display: flex;
  flex-direction: column;
  padding: 12rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
}

.summary-label {
  font-size: 20rpx;
  color: #5a5a70;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8e8f0;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8a8aa0;
}

.empty-sub {
  font-size: 22rpx;
  color: #5a5a70;
  text-align: center;
  max-width: 400rpx;
}
